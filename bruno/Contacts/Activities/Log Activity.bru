meta {
  name: Log Activity
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/api/v1/contacts/contacts/{{contactId}}/activities
  body: json
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

body:json {
  {
    "moduleSource": "contacts",
    "activityType": "ProfileUpdated",
    "summary": "Contact profile was updated",
    "details": "Email and phone number changed"
  }
}
