meta {
  name: Record Consent
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/api/v1/contacts/contacts/{{contactId}}/consents
  body: json
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

body:json {
  {
    "consentType": "EmailMarketing",
    "granted": true,
    "source": "Web Form",
    "ipAddress": "192.168.1.1"
  }
}
