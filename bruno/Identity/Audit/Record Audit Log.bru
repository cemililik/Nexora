meta {
  name: Record Audit Log
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/api/v1/identity/audit-logs
  body: json
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

body:json {
  {
    "userId": "{{userId}}",
    "action": "login",
    "ipAddress": "192.168.1.100",
    "userAgent": "Mozilla/5.0 (Macintosh; Intel Mac OS X 10_15_7)",
    "details": "{\"method\":\"password\",\"mfa\":false}"
  }
}
