meta {
  name: Update Organization
  type: http
  seq: 4
}

put {
  url: {{baseUrl}}/api/v1/identity/organizations/{{organizationId}}
  body: json
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

body:json {
  {
    "name": "Acme Corporation Updated",
    "timezone": "Europe/Istanbul",
    "defaultCurrency": "TRY",
    "defaultLanguage": "tr"
  }
}
