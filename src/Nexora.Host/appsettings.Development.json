{
  "ConnectionStrings": {
    "Default": "Host=localhost;Port=5433;Database=nexora;Username=nexora;Password=CONFIGURE_VIA_USER_SECRETS",
    "Hangfire": "Host=localhost;Port=5433;Database=nexora;Username=nexora;Password=CONFIGURE_VIA_USER_SECRETS"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "Hangfire": "Information"
      }
    }
  },
  "Keycloak": {
    "BaseUrl": "http://localhost:8080",
    "AdminRealm": "master",
    "AdminClientId": "admin-cli"
  },
  "Observability": {
    "Tracing": {
      "Enabled": true,
      "Exporter": "otlp",
      "Endpoint": "http://localhost:4327"
    },
    "Metrics": {
      "Enabled": true,
      "Exporter": "otlp",
      "Endpoint": "http://localhost:4327"
    },
    "Logging": {
      "Exporter": "otlp",
      "OtlpEndpoint": "http://localhost:4327"
    }
  },
  "Vault": {
    "Address": "http://localhost:8200"
  }
}
