# API
NEXT_PUBLIC_API_URL=http://localhost:9080/api/v1

# Authentication (Keycloak)
AUTH_KEYCLOAK_ID=nexora-portal
AUTH_KEYCLOAK_SECRET=your-keycloak-client-secret
AUTH_KEYCLOAK_ISSUER=http://localhost:8080/realms/nexora
AUTH_SECRET=your-nextauth-secret-at-least-32-chars

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Next.js Image Optimization — allowed hostname for tenant logo images
# Set to your MinIO/CDN hostname. Default: cdn.nexora.io
IMAGE_HOSTNAME=cdn.nexora.io

# Allowed hostnames for tenant branding images (comma-separated)
# Used by BrandingProvider for URL validation
NEXT_PUBLIC_ALLOWED_IMAGE_HOSTNAMES=cdn.nexora.io

# Observability
NEXT_PUBLIC_OTEL_ENDPOINT=http://localhost:4328
