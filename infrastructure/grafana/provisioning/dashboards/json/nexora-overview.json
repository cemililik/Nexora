{
  "id": null,
  "uid": "nexora-overview",
  "title": "Nexora — Overview",
  "tags": ["nexora"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Application Logs",
      "type": "logs",
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 0 },
      "datasource": { "uid": "loki", "type": "loki" },
      "targets": [
        {
          "expr": "{exporter=\"OTLP\"} |= ``",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": true,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      }
    },
    {
      "id": 2,
      "title": "HTTP Request Rate (5m)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "uid": "prometheus", "type": "prometheus" },
      "targets": [
        {
          "expr": "rate(nexora_http_server_request_duration_seconds_count[5m])",
          "legendFormat": "{{http_request_method}} {{http_route}} — {{http_response_status_code}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        }
      }
    },
    {
      "id": 3,
      "title": "HTTP Latency p95 (5m)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "uid": "prometheus", "type": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(nexora_http_server_request_duration_seconds_bucket[5m]))",
          "legendFormat": "{{http_request_method}} {{http_route}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      }
    },
    {
      "id": 4,
      "title": "Error Rate (5xx)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 20 },
      "datasource": { "uid": "prometheus", "type": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(nexora_http_server_request_duration_seconds_count{http_response_status_code=~\"5..\"}[5m]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.1 },
              { "color": "red", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "title": "Recent Traces",
      "type": "table",
      "gridPos": { "h": 8, "w": 18, "x": 6, "y": 20 },
      "datasource": { "uid": "tempo", "type": "tempo" },
      "targets": [
        {
          "queryType": "nativeSearch",
          "serviceName": "nexora-api",
          "limit": 20,
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "title": "Logs by Level",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 24 },
      "datasource": { "uid": "loki", "type": "loki" },
      "targets": [
        {
          "expr": "sum by (level) (count_over_time({exporter=\"OTLP\"} | logfmt [5m]))",
          "refId": "A"
        }
      ]
    }
  ]
}
